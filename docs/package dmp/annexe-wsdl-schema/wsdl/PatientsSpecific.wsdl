                <xs:sequence>
                    <xs:element form="qualified" minOccurs="0" name="login" type="xs:string"/>
                    <xs:element form="qualified" minOccurs="0" name="password" type="xs:string"/>
                    <xs:element form="qualified" minOccurs="0" name="status" type="xs:string"/>
                    <xs:element form="qualified" minOccurs="0" name="context" type="xs:string"/>
                </xs:sequence>
            </xs:complexType>
            <xs:complexType name="patientList">
                <xs:sequence>
                    <xs:element form="qualified" minOccurs="0" name="startDate" type="xs:string"/>
