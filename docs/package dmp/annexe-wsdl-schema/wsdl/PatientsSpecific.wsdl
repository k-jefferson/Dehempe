                    <xs:enumeration value="LASTDOC"/>
                </xs:restriction>
            </xs:simpleType>
            <xs:simpleType name="actionTypeEnum">
                <xs:restriction base="xs:string">
                    <xs:enumeration value="AJOUT"/>
                    <xs:enumeration value="MODIFICATION"/>
                    <xs:enumeration value="SUPPRESSION"/>
